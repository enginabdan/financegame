OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
ALLOWED_ORIGINS=http://127.0.0.1:4173,http://localhost:4173
DATABASE_URL=
# Preferred production storage
USE_FIRESTORE=1
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=financegame-78d26.firebasestorage.app
# If you use a service-account JSON locally, point to it.
# Cloud Run can use the default service account with no file path.
GOOGLE_APPLICATION_CREDENTIALS=
# Require Firebase ID token on student endpoints
USE_FIREBASE_AUTH=1
TEACHER_API_KEY=change-me
